# Rivet × Crewline — copy this file to .env and fill in real values.
# .env is loaded automatically on boot (local dev). On Render/Vercel, set these
# in the dashboard instead. Real host env vars always override .env.

# ---- Sessions (required in production) ----
# Long random string used to sign session cookies.
RIVET_SECRET=

# ---- Email OTP (signup verification) — configure ONE of the options below ----
# Option A: any SMTP server via nodemailer. For Gmail: host smtp.gmail.com,
# port 465, user = your Gmail address, pass = an App Password
# (Google Account → Security → 2-Step Verification → App passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# "Name <address>" shown as the sender; defaults to SMTP_USER.
EMAIL_FROM=

# Option B: Resend (resend.com) — requires a verified domain to email anyone.
#RESEND_API_KEY=

# Option C: Brevo (brevo.com) — 300 free emails/day; EMAIL_FROM must be a
# verified sender in your Brevo dashboard.
#BREVO_API_KEY=

# ---- Phone OTP login (real SMS via Twilio) ----
# Until all three are set, phone sign-in is hidden/disabled.
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ---- Google Sign-In (button hidden until both are set) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Admin panel (/admin): comma-separated emails allowed in ----
# e.g. ADMIN_EMAILS=you@gmail.com,cofounder@gmail.com
ADMIN_EMAILS=

# ---- Database (persistent; omit locally to use the data/rivet.db file) ----
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ---- Optional ----
#PORT=3000
#GROQ_API_KEY=          # free AI drafting via Groq
#RIVET_DATA_DIR=        # where the local SQLite file lives
